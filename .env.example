# =============================================================
# Morgan Developers — Environment Variables
# =============================================================

# ── Frontend (safe to expose in browser) ──────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-key>
VITE_SITE_URL=https://<your-domain-or-host>

# ── Backend-only (NEVER expose in frontend) ───────────────────
# Used by Edge Functions and Supabase CLI
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_DB_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres

# ── Edge Function secrets (optional, for lead-notification) ───
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_ADMIN_TO=admin@yourdomain.com
# RESEND_API_KEY=re_xxxxxxxxxx
